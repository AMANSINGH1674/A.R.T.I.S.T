# ============================================================
# ARTIST Environment Configuration
# Copy this file to .env and fill in ALL values marked REQUIRED
# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# Application
APP_NAME=ARTIST
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# API
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated list of allowed origins (no wildcards with credentials)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── REQUIRED ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# Database — REQUIRED for production (SQLite used as fallback for dev only)
DATABASE_URL=postgresql://artist:${POSTGRES_PASSWORD}@localhost:5432/artist
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# Redis — REQUIRED
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# MinIO (Milvus object store) — REQUIRED
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_min_8_chars
# ─────────────────────────────────────────────────────────────

# Vector Database (Milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Pinecone (alternative to Milvus)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# LLM — at least one provider is REQUIRED
# ── Option A: OpenAI ──────────────────────────────
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# ── Option B: Anthropic ───────────────────────────
# ANTHROPIC_API_KEY=
# DEFAULT_LLM_PROVIDER=anthropic
# DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ── Option C: NVIDIA NIM (recommended) ───────────
# Free credits at https://build.nvidia.com
# No GPU required — NVIDIA hosts the models
# NVIDIA_API_KEY=nvapi-...
# DEFAULT_LLM_PROVIDER=nim
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_CHAT_MODEL=meta/llama-3.1-70b-instruct
# ─────────────────────────────────────────────────

# Embeddings provider: "openai" or "nim"
EMBEDDING_PROVIDER=openai
# NIM embedding model (used when EMBEDDING_PROVIDER=nim)
# NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
MAX_REQUEST_LENGTH=10000

# Monitoring & Observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=artist
SENTRY_DSN=

# Tool Configuration
ENABLE_CODE_EXECUTION=true
CODE_EXECUTION_TIMEOUT=30
MAX_CONCURRENT_EXECUTIONS=5

# Workflow Configuration
MAX_WORKFLOW_STEPS=20
WORKFLOW_TIMEOUT=300

# RLHF Configuration
ENABLE_RLHF=false
FEEDBACK_COLLECTION_ENDPOINT=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Web Search
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
